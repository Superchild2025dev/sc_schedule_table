/* ════════════════════════════════════════════════════════════════
 * 선생님 승인 페이지
 * - 각 선생님별로 대기 중인 보강/결석취소 요청 리스트
 * - 수락 → MARK_MAP에 실제 반영
 * - 거절 → 요청 삭제
 * ════════════════════════════════════════════════════════════════ */

const FIREBASE_CONFIG = {
  apiKey: "AIzaSyArHQQfHnVreH8gVamyl1e5IqUDfXUJ5F8",
  authDomain: "scswimming-schedule.firebaseapp.com",
  databaseURL: "https://scswimming-schedule-default-rtdb.asia-southeast1.firebasedatabase.app",
  projectId: "scswimming-schedule",
  storageBucket: "scswimming-schedule.firebasestorage.app",
  messagingSenderId: "45509278949",
  appId: "1:45509278949:web:f16989a9c416f06e25e80c"
};

let _fb=null, _fbReady=false;
let STUDENTS=[], INST_MAP={}, MARK_MAP={}, REQUESTS={}, TEACHERS=[], ATTENDANCE={}, ATT_GUESTS={}, DAY_SNAPSHOT={};
let _currentTeacher=null;
let _activeTab='bogang';
let _attWeekStart=null;

function parseJSON(v,def){
  if(!v) return def;
  try{return typeof v==='string'?JSON.parse(v):v;}catch(e){return def;}
}

function initFirebase(){
  try{
    firebase.initializeApp(FIREBASE_CONFIG);
    _fb=firebase.database().ref('schedule');
    _fbReady=true;
  }catch(e){ console.error('Firebase 실패:',e); }
}

function loadAllData(){
  return new Promise((resolve,reject)=>{
    if(!_fbReady){reject('not ready');return;}
    _fb.once('value').then(snap=>{
      const data=snap.val()||{};
      STUDENTS=parseJSON(data.swim_students,[]);
      INST_MAP=parseJSON(data.swim_inst,{});
      MARK_MAP=parseJSON(data.swim_mark,{});
      REQUESTS=parseJSON(data.swim_requests,{});
      TEACHERS=parseJSON(data.swim_teachers,[]);
      ATTENDANCE=parseJSON(data.swim_attendance,{});
      ATT_GUESTS=parseJSON(data.swim_att_guests,{});
      DAY_SNAPSHOT=parseJSON(data.swim_day_snapshot,{});
      resolve();
    }).catch(reject);
  });
}

function subscribeChanges(){
  if(!_fbReady) return;
  _fb.on('child_changed',snap=>{
    const asStr=typeof snap.val()==='string'?snap.val():JSON.stringify(snap.val());
    if(snap.key==='swim_requests') REQUESTS=parseJSON(asStr,{});
    else if(snap.key==='swim_mark') MARK_MAP=parseJSON(asStr,{});
    else if(snap.key==='swim_students') STUDENTS=parseJSON(asStr,[]);
    else if(snap.key==='swim_inst') INST_MAP=parseJSON(asStr,{});
    else if(snap.key==='swim_teachers') TEACHERS=parseJSON(asStr,[]);
    else if(snap.key==='swim_attendance') ATTENDANCE=parseJSON(asStr,{});
    else if(snap.key==='swim_att_guests') ATT_GUESTS=parseJSON(asStr,{});
    else if(snap.key==='swim_day_snapshot') DAY_SNAPSHOT=parseJSON(asStr,{});
    if(_currentTeacher!==null) render();
  });
}

function saveMark(){ return _fb.child('swim_mark').set(JSON.stringify(MARK_MAP)); }
function saveRequests(){ return _fb.child('swim_requests').set(JSON.stringify(REQUESTS)); }
function saveAttendance(){ return _fb.child('swim_attendance').set(JSON.stringify(ATTENDANCE)); }
function saveAttGuests(){ return _fb.child('swim_att_guests').set(JSON.stringify(ATT_GUESTS)); }
function saveDaySnapshot(){ return _fb.child('swim_day_snapshot').set(JSON.stringify(DAY_SNAPSHOT)); }

/* ── 선생님 선택 ── */
function populateTeachers(){
  const sel=document.getElementById('teacher-pick');
  sel.innerHTML='<option value="">선택하세요</option>';
  // INST_MAP에서 이름 수집 (중복 제거)
  const names=new Set();
  Object.values(INST_MAP).forEach(inst=>{
    if(inst?.n) names.add(inst.n);
  });
  // TEACHERS 목록에서도 추가
  TEACHERS.forEach(t=>{ if(t?.n) names.add(t.n); });
  [...names].sort().forEach(n=>{
    const opt=document.createElement('option');
    opt.value=n;opt.textContent=n;
    sel.appendChild(opt);
  });
}

function enterAsTeacher(teacherName){
  _currentTeacher=teacherName;  // '' = 전체
  try{sessionStorage.setItem('teacher_name',teacherName);}catch(e){}
  document.getElementById('teacher-select-screen').style.display='none';
  document.getElementById('teacher-dashboard').style.display='flex';
  document.getElementById('teacher-display').textContent=
    teacherName ? `${teacherName} 선생님` : '전체 관리자';
  render();
}

function logout(){
  _currentTeacher=null;
  try{sessionStorage.removeItem('teacher_name');}catch(e){}
  document.getElementById('teacher-dashboard').style.display='none';
  document.getElementById('teacher-select-screen').style.display='flex';
}

/* ── 요청 필터링 ── */
function getMyRequests(type){
  // _currentTeacher가 '' (전체)이면 모두 보기
  const results=[];
  for(const [reqId,req] of Object.entries(REQUESTS)){
    if(req.type!==type) continue;
    if(req.status==='pending' || !req.status){
      // 선생님 필터
      if(_currentTeacher){
        // bogang: target의 선생님이 내 이름이어야 함
        // absent-cancel: 원생의 담임 선생님이 내 이름이어야 함
        const inst=INST_MAP[req.instKey];
        if(inst?.n !== _currentTeacher) continue;
      }
      results.push([reqId,req]);
    }
  }
  // 최신순
  results.sort((a,b)=>(b[1].requestedAt||'').localeCompare(a[1].requestedAt||''));
  return results;
}

function render(){
  if(_activeTab==='attendance'){
    renderAttendanceTimetable();
  }
  const bogangReqs=getMyRequests('bogang');
  const cancelReqs=getMyRequests('absent-cancel');

  document.getElementById('cnt-bogang').textContent=bogangReqs.length;
  document.getElementById('cnt-bogang').dataset.n=bogangReqs.length;
  document.getElementById('cnt-cancel').textContent=cancelReqs.length;
  document.getElementById('cnt-cancel').dataset.n=cancelReqs.length;

  document.getElementById('teacher-stats').textContent=
    `승인 대기 — 보강 ${bogangReqs.length}건 · 결석취소 ${cancelReqs.length}건`;

  renderBogangList(bogangReqs);
  renderCancelList(cancelReqs);
}

function fmtDate(ds){
  if(!ds) return '';
  const dow=['일','월','화','수','목','금','토'][new Date(ds).getDay()];
  const [y,m,d]=ds.split('-');
  return `${parseInt(m)}/${parseInt(d)}(${dow})`;
}
function fmtTime(iso){
  if(!iso) return '';
  const d=new Date(iso);
  return `${d.getMonth()+1}/${d.getDate()} ${String(d.getHours()).padStart(2,'0')}:${String(d.getMinutes()).padStart(2,'0')}`;
}

function renderBogangList(reqs){
  const container=document.getElementById('bogang-list');
  if(!reqs.length){
    container.innerHTML='<div class="req-empty">승인 대기 중인 보강 신청이 없습니다.</div>';
    return;
  }
  container.innerHTML=reqs.map(([id,r])=>{
    const p=r.parent, t=r.target;
    const parentInfo=`${p.name}${p.age?'('+p.age+'살)':''}`;
    const [ot,od,ol,or2]=(p.studentSlotKey||'').split('/');
    const origin=p.studentSlotKey ? `${od}요일 ${ot} ${ol}레인 ${or2}번` : '';
    return `<div class="req-card">
      <div class="req-hdr">
        <span class="req-type">보강 신청</span>
        <span class="req-time">${fmtTime(r.requestedAt)}</span>
      </div>
      <div class="req-main">
        <div class="parent-name">${esc(parentInfo)}${p.phone?'  '+esc(p.phone):''}</div>
        <div class="sub-info">원래 수업: ${esc(origin)}</div>
        <div class="target">📅 ${fmtDate(t.ds)} ${esc(t.d)}요일 ${esc(t.t)} · ${t.l}레인 ${t.r}번 · ${esc(t.instName||'')}</div>
      </div>
      <div class="req-actions">
        <button class="btn-reject" data-act="reject" data-id="${id}">거절</button>
        <button class="btn-accept" data-act="accept" data-id="${id}">수락</button>
      </div>
    </div>`;
  }).join('');
}

function renderCancelList(reqs){
  const container=document.getElementById('cancel-list');
  if(!reqs.length){
    container.innerHTML='<div class="req-empty">승인 대기 중인 결석 취소 신청이 없습니다.</div>';
    return;
  }
  container.innerHTML=reqs.map(([id,r])=>{
    const p=r.parent, t=r.target;
    const parentInfo=`${p.name}${p.age?'('+p.age+'살)':''}`;
    return `<div class="req-card cancel">
      <div class="req-hdr">
        <span class="req-type cancel">결석 취소 요청</span>
        <span class="req-time">${fmtTime(r.requestedAt)}</span>
      </div>
      <div class="req-main">
        <div class="parent-name">${esc(parentInfo)}${p.phone?'  '+esc(p.phone):''}</div>
        <div class="target">❌ ${fmtDate(t.ds)} ${esc(t.d)}요일 ${esc(t.t)} · ${t.l}레인 ${t.r}번 결석 취소</div>
      </div>
      <div class="req-actions">
        <button class="btn-reject" data-act="reject" data-id="${id}">거절 (결석 유지)</button>
        <button class="btn-accept" data-act="accept" data-id="${id}">수락 (결석 해제)</button>
      </div>
    </div>`;
  }).join('');
}

/* ── 수락/거절 액션 ── */
async function acceptRequest(reqId){
  const req=REQUESTS[reqId];
  if(!req) return;
  try{
    if(req.type==='bogang'){
      const t=req.target;
      const markKey=`${t.t}/${t.d}/${t.l}/${t.r}/${t.ds}`;
      const existing=MARK_MAP[markKey];
      if(existing?.type==='absent'&&existing.sub){toast('이미 다른 마크가 있습니다','err');return;}
      if(existing&&existing.type!=='absent'){toast('이미 다른 마크가 있습니다','err');return;}

      const bogangObj={type:'bogang', n:req.parent.name, a:req.parent.age||null};
      if(req.parent.phone) bogangObj.p=req.parent.phone;

      // 결석이 있으면 sub로 붙임
      if(existing?.type==='absent'){
        MARK_MAP[markKey]={type:'absent', sub:bogangObj};
      } else {
        MARK_MAP[markKey]=bogangObj;
      }
      await saveMark();
      // 학부모 쪽 원래 슬롯은 자동 결석 처리 안 함 (학부모가 직접 결석 신청해야 함)
    } else if(req.type==='absent-cancel'){
      const t=req.target;
      const markKey=`${t.t}/${t.d}/${t.l}/${t.r}/${t.ds}`;
      const cur=MARK_MAP[markKey];
      if(cur?.type==='absent'){
        if(cur.sub) MARK_MAP[markKey]=cur.sub;
        else delete MARK_MAP[markKey];
        await saveMark();
      }
    }
    delete REQUESTS[reqId];
    await saveRequests();
    toast('수락 완료','ok');
    render();
  }catch(e){
    toast('처리 실패','err');
    console.error(e);
  }
}

async function rejectRequest(reqId){
  const req=REQUESTS[reqId];
  if(!req) return;
  if(!confirm('이 요청을 거절하시겠습니까?')) return;
  try{
    delete REQUESTS[reqId];
    await saveRequests();
    toast('거절 완료','ok');
    render();
  }catch(e){
    toast('처리 실패','err');
    console.error(e);
  }
}

/* ════════════════════════════════════════════════════════════════
 * 출석
 * ════════════════════════════════════════════════════════════════ */
function toDateStr(d){
  const y=d.getFullYear();
  const m=String(d.getMonth()+1).padStart(2,'0');
  const dd=String(d.getDate()).padStart(2,'0');
  return `${y}-${m}-${dd}`;
}

// 해당 날짜의 요일 한글
function dayOfDate(ds){
  return ['일','월','화','수','목','금','토'][new Date(ds).getDay()];
}

// 선택된 선생님의 해당 날짜 학생 슬롯들 수집
function getAttendanceSlots(ds){
  const day=dayOfDate(ds);
  const slots=[];  // [{t, day, l, instName, students:[{slotKey,n,a,...}, ...]}]
  const byTime={};

  // INST_MAP 순회 → 내 이름 슬롯 찾기
  for(const [instKey,inst] of Object.entries(INST_MAP)){
    const [t,d,l]=instKey.split('/');
    if(d!==day) continue;
    if(!inst?.n) continue;
    // 선생님 필터 (_currentTeacher가 ''이면 전체)
    if(_currentTeacher && inst.n!==_currentTeacher) continue;
    const key=t+'/'+d+'/'+l;
    byTime[key]={t, day:d, lane:parseInt(l), instName:inst.n, slotGroupKey:key, students:[]};
  }

  // 해당 슬롯의 학생들 수집 (+ 보강/샘플로 오는 학생도 포함)
  for(const [k,info] of Object.entries(byTime)){
    // 정규 학생
    STUDENTS.forEach(s=>{
      if(s.t===info.t&&s.d===info.day&&s.l===info.lane){
        // 그 날 결석이면 → 결석 표시하되 리스트에는 포함
        info.students.push({
          slotKey: info.t+'/'+info.day+'/'+info.lane+'/'+s.r,
          n:s.n, a:s.a||null, p:s.p||null,
          row:s.r,
          type:'regular'
        });
      }
    });
    // 보강/샘플 (그날 방문 학생)
    for(let r=1;r<=8;r++){
      const mk=MARK_MAP[info.t+'/'+info.day+'/'+info.lane+'/'+r+'/'+ds];
      if(!mk) continue;
      const sub=mk.type==='absent'?mk.sub:mk;
      if(sub&&(sub.type==='bogang'||sub.type==='sample')){
        // 이미 정규 학생 목록에 같은 row가 있으면 그 학생(결석)은 별개
        // 단, 정규 학생이 row에 있고 그 정규학생이 MARK의 bogang이면 이상한 경우. 대개 결석+sub 조합임
        info.students.push({
          slotKey: info.t+'/'+info.day+'/'+info.lane+'/'+r,
          n:sub.n, a:sub.a||null, p:sub.p||null,
          row:r,
          type:sub.type  // 'bogang' | 'sample'
        });
      }
    }
    // row 순 정렬
    info.students.sort((a,b)=>a.row-b.row);
    slots.push(info);
  }

  // 시간/레인 순
  slots.sort((a,b)=>{
    const ta=parseInt(a.t), tb=parseInt(b.t);
    if(ta!==tb) return ta-tb;
    return a.lane-b.lane;
  });
  return slots;
}

function renderAttendance(){
  const ds=document.getElementById('att-date').value || toDateStr(new Date());
  _attDate=ds;
  const slots=getAttendanceSlots(ds);

  // 통계
  const stats={total:0, present:0, absent:0, unchecked:0};
  const countAtt=(s)=>{
    if(!s) stats.unchecked++;
    else if(s==='present') stats.present++;
    else if(s==='absent') stats.absent++;
    else stats.unchecked++;
  };
  slots.forEach(slot=>{
    slot.students.forEach(stu=>{
      stats.total++;
      const att=ATTENDANCE[stu.slotKey+'/'+ds];
      const s=att?(typeof att==='string'?att:att.s):null;
      countAtt(s);
    });
    // 게스트 집계
    const guests=ATT_GUESTS[slot.slotGroupKey+'/'+ds]||[];
    guests.forEach(g=>{stats.total++; countAtt(g.s);});
  });
  document.getElementById('att-stats').innerHTML=
    `<span class="st">👥 총 ${stats.total}명</span>`+
    `<span class="st">✅ 출석 ${stats.present}</span>`+
    `<span class="st">❌ 결석 ${stats.absent}</span>`+
    (stats.unchecked>0?`<span class="st" style="color:#9CA3AF">⚪ 미체크 ${stats.unchecked}</span>`:'');

  // 슬롯 목록
  const list=document.getElementById('att-list');
  if(!slots.length){
    list.innerHTML='<div class="att-empty">해당 날짜에 수업이 없습니다.</div>';
    return;
  }
  list.innerHTML=slots.map(slot=>{
    const slotGroupKey=slot.slotGroupKey;
    const guests=ATT_GUESTS[slotGroupKey+'/'+ds]||[];
    const totalCount=slot.students.length+guests.length;

    const btnsHtml=(slotKey,cur,isGuest,gid)=>{
      const base=isGuest?`data-act="att-guest" data-sgk="${esc(slotGroupKey)}" data-ds="${ds}" data-gid="${esc(gid)}"`
                         :`data-act="att" data-slot="${esc(slotKey)}" data-ds="${ds}"`;
      return [{v:'present',label:'출석',cls:'present'},{v:'absent',label:'결석',cls:'absent'}]
        .map(b=>`<button class="att-btn ${b.cls}${cur===b.v?' active':''}" ${base} data-val="${b.v}">${b.label}</button>`)
        .join('');
    };

    // 정규 학생 행
    const regRows=slot.students.map(stu=>{
      const att=ATTENDANCE[stu.slotKey+'/'+ds];
      const cur=att?(typeof att==='string'?att:att.s):'';
      const typeBadge=stu.type==='bogang'?'<span class="att-student-meta" style="color:#7C3AED">보강</span>':
                      stu.type==='sample'?'<span class="att-student-meta" style="color:#F59E0B">샘플</span>':'';
      return `<div class="att-student-row">
        <span class="att-student-name">${esc(stu.n)}${stu.a?'('+stu.a+')':''} ${typeBadge}</span>
        <div class="att-btns">${btnsHtml(stu.slotKey,cur)}</div>
      </div>`;
    }).join('');

    // 게스트 행
    const guestRows=guests.map(g=>`<div class="att-student-row">
      <span class="att-student-name">${esc(g.n)}${g.a?'('+g.a+')':''} <span class="att-student-meta" style="color:#10B981">+추가</span></span>
      <div class="att-btns">${btnsHtml('',g.s||'',true,g.gid)}<button class="att-btn" data-act="del-guest" data-sgk="${esc(slotGroupKey)}" data-ds="${ds}" data-gid="${esc(g.gid)}" style="color:#EF4444;border-color:#FCA5A5" title="삭제">✕</button></div>
    </div>`).join('');

    return `<div class="att-slot-group">
      <div class="att-slot-title">${esc(slot.t)} · ${slot.lane}레인 · ${esc(slot.instName)} 선생님 (${totalCount}명)</div>
      ${regRows||'<div class="att-student-row"><span style="color:#9CA3AF;font-size:12px">학생 없음</span></div>'}
      ${guestRows}
      <div class="att-student-row" style="background:#F9FAFB">
        <button class="att-btn" data-act="add-guest" data-sgk="${esc(slotGroupKey)}" data-ds="${ds}" style="color:#3B82F6;border-color:#93C5FD;font-size:11px;padding:6px 12px">＋ 아이 추가</button>
      </div>
    </div>`;
  }).join('');
}

async function setAttendance(slotKey, ds, value){
  const key=slotKey+'/'+ds;
  const cur=ATTENDANCE[key];
  const curVal=cur?(typeof cur==='string'?cur:cur.s):null;
  // 같은 값 클릭 → 취소 (미체크)
  if(curVal===value){
    delete ATTENDANCE[key];
  } else {
    ATTENDANCE[key]={s:value, at:new Date().toISOString(), by:_currentTeacher||null};
  }
  try{
    await saveAttendance();
    renderAttendance();
  }catch(e){
    toast('저장 실패','err');
    console.error(e);
  }
}

/* ────────────────────────────────────────────────────────────────
 * 주간 현황판
 * ──────────────────────────────────────────────────────────────── */
function getMondayOf(date){
  const d=new Date(date);
  const dow=d.getDay();  // 0=일, 1=월, ...
  const offset=dow===0?-6:1-dow;  // 일요일이면 -6 (전주 월요일)
  d.setDate(d.getDate()+offset);
  return toDateStr(d);
}

function getWeekDates(monday){
  const out=[];
  const d=new Date(monday);
  for(let i=0;i<6;i++){  // 월~토 6일
    out.push({ds:toDateStr(d), dow:['일','월','화','수','목','금','토'][d.getDay()]});
    d.setDate(d.getDate()+1);
  }
  return out;
}

// 선택 선생님의 모든 수업 슬롯 (time, day, lane, instName) 수집 (주간용)
function getAllTeacherSlots(){
  const slots=[];
  for(const [instKey,inst] of Object.entries(INST_MAP)){
    const [t,d,l]=instKey.split('/');
    if(!inst?.n) continue;
    if(_currentTeacher && inst.n!==_currentTeacher) continue;
    slots.push({t, day:d, lane:parseInt(l), instName:inst.n, slotGroupKey:t+'/'+d+'/'+l});
  }
  // 시간/요일/레인 정렬
  const dayOrder={'월':1,'화':2,'수':3,'목':4,'금':5,'토':6,'일':0};
  slots.sort((a,b)=>{
    const ta=parseInt(a.t), tb=parseInt(b.t);
    if(ta!==tb) return ta-tb;
    if(a.lane!==b.lane) return a.lane-b.lane;
    return dayOrder[a.day]-dayOrder[b.day];
  });
  return slots;
}

// 특정 슬롯(time, lane)을 공유하는 요일들로 그룹화
function groupSlotsByTimeLane(slots){
  const groups={};  // key: time/lane → {t, lane, byDay:{day:slotInfo}}
  slots.forEach(s=>{
    const k=s.t+'/'+s.lane;
    if(!groups[k]) groups[k]={t:s.t, lane:s.lane, byDay:{}};
    groups[k].byDay[s.day]=s;
  });
  return Object.values(groups);
}

function renderAttendanceWeek(){
  const todayStr=toDateStr(new Date());
  if(!_attWeekStart) _attWeekStart=getMondayOf(new Date());
  const weekDates=getWeekDates(_attWeekStart);
  const endDs=weekDates[weekDates.length-1].ds;

  // 라벨
  const [sy,sm,sd]=_attWeekStart.split('-');
  const [ey,em,ed]=endDs.split('-');
  document.getElementById('att-week-label').textContent=
    `${parseInt(sm)}/${parseInt(sd)} ~ ${parseInt(em)}/${parseInt(ed)}`;

  const allSlots=getAllTeacherSlots();
  if(!allSlots.length){
    document.getElementById('att-week-view').innerHTML=
      '<div class="att-empty">담당 수업이 없습니다.</div>';
    document.getElementById('att-stats').innerHTML='';
    return;
  }
  const groups=groupSlotsByTimeLane(allSlots);

  // 주간 통계
  let total=0, present=0, absent=0, unchecked=0;
  groups.forEach(grp=>{
    weekDates.forEach(({ds,dow})=>{
      const slot=grp.byDay[dow];
      if(!slot) return;
      // 정규 학생
      STUDENTS.forEach(s=>{
        if(s.t===slot.t&&s.d===slot.day&&s.l===slot.lane){
          total++;
          const att=ATTENDANCE[slot.t+'/'+slot.day+'/'+slot.lane+'/'+s.r+'/'+ds];
          const v=att?(typeof att==='string'?att:att.s):null;
          if(v==='present') present++;
          else if(v==='absent') absent++;
          else unchecked++;
        }
      });
      // 보강/샘플 (MARK_MAP)
      for(let r=1;r<=8;r++){
        const mk=MARK_MAP[slot.t+'/'+slot.day+'/'+slot.lane+'/'+r+'/'+ds];
        if(!mk) continue;
        const sub=mk.type==='absent'?mk.sub:mk;
        if(sub&&(sub.type==='bogang'||sub.type==='sample')){
          total++;
          const att=ATTENDANCE[slot.t+'/'+slot.day+'/'+slot.lane+'/'+r+'/'+ds];
          const v=att?(typeof att==='string'?att:att.s):null;
          if(v==='present') present++;
          else if(v==='absent') absent++;
          else unchecked++;
        }
      }
      // 게스트
      const guests=ATT_GUESTS[slot.slotGroupKey+'/'+ds]||[];
      guests.forEach(g=>{
        total++;
        if(g.s==='present') present++;
        else if(g.s==='absent') absent++;
        else unchecked++;
      });
    });
  });
  document.getElementById('att-stats').innerHTML=
    `<span class="st">👥 총 ${total}명</span>`+
    `<span class="st">✅ 출석 ${present}</span>`+
    `<span class="st">❌ 결석 ${absent}</span>`+
    (unchecked>0?`<span class="st" style="color:#9CA3AF">⚪ 미체크 ${unchecked}</span>`:'');

  // 테이블 HTML
  let html='<div class="week-grid-wrap"><table class="week-grid"><thead><tr>';
  html+='<th style="min-width:80px;position:sticky;left:0;z-index:2;background:#F3F4F6">시간/레인</th>';
  weekDates.forEach(({ds,dow})=>{
    const [y,m,d]=ds.split('-');
    const today=ds===todayStr;
    html+=`<th class="${today?'today-col':''}">${dow}<br><span style="font-size:10px;font-weight:500">${parseInt(m)}/${parseInt(d)}</span></th>`;
  });
  html+='</tr></thead><tbody>';

  groups.forEach(grp=>{
    html+='<tr>';
    // 첫 요일 slot의 선생님 이름 (대표)
    const repSlot=Object.values(grp.byDay)[0];
    const instNm=repSlot?.instName||'';
    html+=`<td class="slot-row-label">${esc(grp.t)} ${grp.lane}레인<span class="t-inst">${esc(instNm)}</span></td>`;

    weekDates.forEach(({ds,dow})=>{
      const slot=grp.byDay[dow];
      if(!slot){
        html+='<td class="no-class-cell">—</td>';
        return;
      }
      html+='<td class="day-cell">';
      html+='<div class="chip-list">';

      // 정규 학생들
      const rowStudents=[];
      STUDENTS.forEach(s=>{
        if(s.t===slot.t&&s.d===slot.day&&s.l===slot.lane){
          rowStudents.push({n:s.n,a:s.a,row:s.r,type:'regular',
            slotKey:slot.t+'/'+slot.day+'/'+slot.lane+'/'+s.r});
        }
      });
      // 보강/샘플
      for(let r=1;r<=8;r++){
        const mk=MARK_MAP[slot.t+'/'+slot.day+'/'+slot.lane+'/'+r+'/'+ds];
        if(!mk) continue;
        const sub=mk.type==='absent'?mk.sub:mk;
        if(sub&&(sub.type==='bogang'||sub.type==='sample')){
          rowStudents.push({n:sub.n,a:sub.a,row:r,type:sub.type,
            slotKey:slot.t+'/'+slot.day+'/'+slot.lane+'/'+r});
        }
      }
      rowStudents.sort((a,b)=>a.row-b.row);
      rowStudents.forEach(stu=>{
        const att=ATTENDANCE[stu.slotKey+'/'+ds];
        const v=att?(typeof att==='string'?att:att.s):'';
        const cls=v==='present'?' present':v==='absent'?' absent':'';
        const mark=v==='present'?'✓':v==='absent'?'✗':'○';
        const typeLabel=stu.type==='bogang'?'<span class="chip-sub">보</span>':
                        stu.type==='sample'?'<span class="chip-sub">샘</span>':'';
        html+=`<div class="stu-chip${cls}" data-act="wk-toggle" data-slot="${esc(stu.slotKey)}" data-ds="${ds}">
          <span class="chip-mark">${mark}</span>
          <span class="chip-name">${esc(stu.n)}${stu.a?stu.a:''}</span>${typeLabel}
        </div>`;
      });
      // 게스트
      const guests=ATT_GUESTS[slot.slotGroupKey+'/'+ds]||[];
      guests.forEach(g=>{
        const cls=g.s==='present'?' present':g.s==='absent'?' absent':'';
        const mark=g.s==='present'?'✓':g.s==='absent'?'✗':'○';
        html+=`<div class="stu-chip${cls}" data-act="wk-toggle-guest" data-sgk="${esc(slot.slotGroupKey)}" data-ds="${ds}" data-gid="${esc(g.gid)}">
          <span class="chip-mark">${mark}</span>
          <span class="chip-name">${esc(g.n)}${g.a?g.a:''}</span>
          <span class="chip-sub" style="color:#10B981">+</span>
          <span class="chip-del" data-act="wk-del-guest" data-sgk="${esc(slot.slotGroupKey)}" data-ds="${ds}" data-gid="${esc(g.gid)}">✕</span>
        </div>`;
      });
      // + 추가
      html+=`<span class="add-chip" data-act="wk-add-guest" data-sgk="${esc(slot.slotGroupKey)}" data-ds="${ds}">＋ 추가</span>`;
      html+='</div></td>';
    });
    html+='</tr>';
  });
  html+='</tbody></table></div>';
  document.getElementById('att-week-view').innerHTML=html;
}

// 주간 현황판에서 클릭: 출석→결석→미체크 순환
async function cycleAttendance(slotKey, ds){
  const key=slotKey+'/'+ds;
  const cur=ATTENDANCE[key];
  const curVal=cur?(typeof cur==='string'?cur:cur.s):null;
  let next;
  if(!curVal) next='present';
  else if(curVal==='present') next='absent';
  else next=null;  // absent → 미체크

  if(next===null) delete ATTENDANCE[key];
  else ATTENDANCE[key]={s:next, at:new Date().toISOString(), by:_currentTeacher||null};

  try{
    await saveAttendance();
    renderAttendanceWeek();
  }catch(e){toast('저장 실패','err');}
}

// 주간 현황판에서 게스트 클릭: 출석→결석→미체크 순환
async function cycleGuestAttendance(sgk, ds, gid){
  const key=sgk+'/'+ds;
  const list=ATT_GUESTS[key]||[];
  const idx=list.findIndex(g=>g.gid===gid);
  if(idx<0) return;
  const cur=list[idx].s;
  let next;
  if(!cur) next='present';
  else if(cur==='present') next='absent';
  else next=null;
  if(next===null) list[idx].s=null;
  else { list[idx].s=next; list[idx].at=new Date().toISOString(); list[idx].by=_currentTeacher||null; }
  ATT_GUESTS[key]=list;
  try{
    await saveAttGuests();
    renderAttendanceWeek();
  }catch(e){toast('저장 실패','err');}
}

async function setGuestAttendance(sgk, ds, gid, value){
  const key=sgk+'/'+ds;
  const list=ATT_GUESTS[key]||[];
  const idx=list.findIndex(g=>g.gid===gid);
  if(idx<0) return;
  const cur=list[idx].s;
  if(cur===value){
    list[idx].s=null;  // 미체크로 되돌림
  } else {
    list[idx].s=value;
    list[idx].at=new Date().toISOString();
    list[idx].by=_currentTeacher||null;
  }
  ATT_GUESTS[key]=list;
  try{
    await saveAttGuests();
    renderAttendance();
  }catch(e){
    toast('저장 실패','err');console.error(e);
  }
}

async function addGuest(sgk, ds){
  const name=prompt('추가할 학생 이름');
  if(!name||!name.trim()) return;
  const ageStr=prompt('나이 (선택, 건너뛰려면 빈칸)')||'';
  const age=parseInt(ageStr)||null;
  const key=sgk+'/'+ds;
  if(!ATT_GUESTS[key]) ATT_GUESTS[key]=[];
  const gid='g_'+Date.now()+'_'+Math.random().toString(36).slice(2,6);
  ATT_GUESTS[key].push({
    gid, n:name.trim(), a:age,
    s:'present',  // 기본 출석으로
    at:new Date().toISOString(),
    by:_currentTeacher||null,
  });
  try{
    await saveAttGuests();
    toast(name+' 추가 · 출석 처리','ok');
    renderAttendance();
  }catch(e){
    toast('저장 실패','err');console.error(e);
  }
}

async function deleteGuest(sgk, ds, gid){
  if(!confirm('이 학생을 목록에서 삭제하시겠습니까?')) return;
  const key=sgk+'/'+ds;
  const list=ATT_GUESTS[key]||[];
  const filtered=list.filter(g=>g.gid!==gid);
  if(filtered.length) ATT_GUESTS[key]=filtered;
  else delete ATT_GUESTS[key];
  try{
    await saveAttGuests();
    toast('삭제 완료','ok');
    renderAttendance();
  }catch(e){
    toast('저장 실패','err');console.error(e);
  }
}

async function markAllPresent(){
  const ds=_attDate;
  if(!ds) return;
  const slots=getAttendanceSlots(ds);
  const now=new Date().toISOString();
  let changed=0, guestChanged=0;
  slots.forEach(slot=>{
    slot.students.forEach(stu=>{
      const key=stu.slotKey+'/'+ds;
      const cur=ATTENDANCE[key];
      const curVal=cur?(typeof cur==='string'?cur:cur.s):null;
      if(!curVal){
        ATTENDANCE[key]={s:'present', at:now, by:_currentTeacher||null};
        changed++;
      }
    });
    // 게스트도 처리
    const gKey=slot.slotGroupKey+'/'+ds;
    (ATT_GUESTS[gKey]||[]).forEach(g=>{
      if(!g.s){g.s='present';g.at=now;g.by=_currentTeacher||null;guestChanged++;}
    });
  });
  if(changed===0&&guestChanged===0){toast('체크할 학생이 없습니다','err');return;}
  try{
    if(changed>0) await saveAttendance();
    if(guestChanged>0) await saveAttGuests();
    toast((changed+guestChanged)+'명 출석 처리','ok');
    renderAttendance();
  }catch(e){
    toast('저장 실패','err');
    console.error(e);
  }
}

function esc(s){return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');}
function toast(msg,type){
  const el=document.getElementById('toast');
  el.textContent=msg;
  el.className='toast show '+(type||'');
  clearTimeout(toast._t);
  toast._t=setTimeout(()=>{el.classList.remove('show');},2400);
}

document.addEventListener('DOMContentLoaded', async ()=>{
  initFirebase();
  try{
    await loadAllData();
    subscribeChanges();
  }catch(e){toast('연결 실패','err');return;}

  populateTeachers();

  // 세션 복구
  try{
    const saved=sessionStorage.getItem('teacher_name');
    if(saved!==null) enterAsTeacher(saved);
  }catch(e){}

  // 이벤트
  document.getElementById('teacher-enter').addEventListener('click',()=>{
    const name=document.getElementById('teacher-pick').value;
    if(!name){toast('선생님을 선택해주세요','err');return;}
    enterAsTeacher(name);
  });
  document.getElementById('teacher-all').addEventListener('click',()=>enterAsTeacher(''));
  document.getElementById('teacher-logout').addEventListener('click',()=>{
    if(confirm('로그아웃하시겠습니까?')) logout();
  });

  // 탭 전환
  document.querySelectorAll('.tab-btn').forEach(btn=>{
    btn.addEventListener('click',()=>{
      document.querySelectorAll('.tab-btn').forEach(b=>b.classList.remove('active'));
      btn.classList.add('active');
      _activeTab=btn.dataset.tab;
      document.getElementById('bogang-list').style.display=_activeTab==='bogang'?'flex':'none';
      document.getElementById('cancel-list').style.display=_activeTab==='cancel'?'flex':'none';
      document.getElementById('attendance-panel').style.display=_activeTab==='attendance'?'block':'none';
      if(_activeTab==='attendance'){
        // 날짜 기본값 오늘
        const dateEl=document.getElementById('att-date');
        if(!dateEl.value) dateEl.value=toDateStr(new Date());
        renderAttendance();
      }
    });
  });

  // 출석 날짜 변경
  document.getElementById('att-date').addEventListener('change',()=>{
    renderAttendance();
  });

  // 모두 출석 버튼
  document.getElementById('att-save-all').addEventListener('click',markAllPresent);

  // 출석 버튼 위임 + 게스트 추가/삭제 + 주간 현황판
  document.addEventListener('click',e=>{
    const btn=e.target.closest('[data-act]');
    if(!btn) return;
    const act=btn.dataset.act;
    const ds=btn.dataset.ds;
    if(act==='att'){
      setAttendance(btn.dataset.slot, ds, btn.dataset.val);
    } else if(act==='att-guest'){
      setGuestAttendance(btn.dataset.sgk, ds, btn.dataset.gid, btn.dataset.val);
    } else if(act==='add-guest' || act==='wk-add-guest'){
      addGuest(btn.dataset.sgk, ds);
    } else if(act==='del-guest' || act==='wk-del-guest'){
      e.stopPropagation();
      deleteGuest(btn.dataset.sgk, ds, btn.dataset.gid);
    } else if(act==='wk-toggle'){
      cycleAttendance(btn.dataset.slot, ds);
    } else if(act==='wk-toggle-guest'){
      cycleGuestAttendance(btn.dataset.sgk, ds, btn.dataset.gid);
    }
  });

  // 일간/주간 모드 토글
  document.querySelectorAll('.att-mode-btn').forEach(btn=>{
    btn.addEventListener('click',()=>{
      document.querySelectorAll('.att-mode-btn').forEach(b=>b.classList.remove('active'));
      btn.classList.add('active');
      _attMode=btn.dataset.mode;
      document.getElementById('att-day-controls').style.display=_attMode==='day'?'flex':'none';
      document.getElementById('att-week-controls').style.display=_attMode==='week'?'flex':'none';
      document.getElementById('att-list').style.display=_attMode==='day'?'block':'none';
      document.getElementById('att-week-view').style.display=_attMode==='week'?'block':'none';
      if(_attMode==='week'){
        if(!_attWeekStart) _attWeekStart=getMondayOf(new Date());
        renderAttendanceWeek();
      } else {
        renderAttendance();
      }
    });
  });

  // 주간 네비게이션
  document.getElementById('att-week-prev').addEventListener('click',()=>{
    const d=new Date(_attWeekStart);d.setDate(d.getDate()-7);
    _attWeekStart=toDateStr(d);renderAttendanceWeek();
  });
  document.getElementById('att-week-next').addEventListener('click',()=>{
    const d=new Date(_attWeekStart);d.setDate(d.getDate()+7);
    _attWeekStart=toDateStr(d);renderAttendanceWeek();
  });
  document.getElementById('att-week-today').addEventListener('click',()=>{
    _attWeekStart=getMondayOf(new Date());renderAttendanceWeek();
  });

  // 수락/거절 위임
  document.addEventListener('click',e=>{
    const btn=e.target.closest('[data-act]');
    if(!btn) return;
    const act=btn.dataset.act;
    const id=btn.dataset.id;
    if(act==='accept') acceptRequest(id);
    else if(act==='reject') rejectRequest(id);
  });
});
